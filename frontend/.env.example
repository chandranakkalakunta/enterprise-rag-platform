# Frontend public env (safe for browser bundle)
# Copy to frontend/.env.local for local development.

# Backend API base (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth Web client ID (same as GOOGLE_OAUTH_CLIENT_ID on API)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Health poll interval for version auto-reload (ms). Default 60000.
# NEXT_PUBLIC_HEALTH_POLL_MS=60000
