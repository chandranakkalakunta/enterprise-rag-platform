# Enterprise RAG Platform — environment variable template
# Copy to .env for local development. Never commit real secrets.
# Production secrets live in Google Secret Manager.

# GCP (set via env; never hard-code in application source)
# Current dev example project number: 642114828076
GCP_PROJECT_ID=enterprise-rag-platform-502711
GCP_REGION=asia-south1

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=local
# Cloud Run / CI inject these at deploy time (NFR-REL-03a)
APP_VERSION=dev
DEPLOYED_AT=

# Document upload
GCS_DOCS_BUCKET=rag-docs-dev
MAX_UPLOAD_BYTES=52428800

# Auth (Phase 5.1 / ADR-0009)
# true = local/tests only (fake admin). Shared envs MUST set false.
AUTH_DEV_BYPASS=true
# Google OAuth Web client ID (audience for ID token verification)
GOOGLE_OAUTH_CLIENT_ID=
# Comma-separated bootstrap elevated roles (lowercased match)
ADMIN_EMAILS=
CONTENT_ADMIN_EMAILS=
ALLOWED_EMAIL_DOMAINS=chandraailabs.com,gmail.com
# CORS (comma-separated origins for browser frontend)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (public — also see frontend/.env.example)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Vertex AI / retrieval (Phase 3.0–3.1 ADR-0007 / ADR-0008)
VERTEX_LOCATION=asia-south1
EMBEDDING_MODEL_ID=text-embedding-005
EMBEDDING_BATCH_SIZE=32
GENERATION_MODEL_ID=gemini-2.0-flash-001
GENERATION_TEMPERATURE=0.2
RETRIEVAL_TOP_K=5
# Optional: refuse if all hit scores are below this value
# EVIDENCE_MIN_SCORE=
# Vector Search (Phase 3.2–3.3) — set after terraform apply; leave disabled for local unit tests
VECTOR_SEARCH_ENABLED=false
VECTOR_SEARCH_REGION=asia-south1
# VECTOR_SEARCH_INDEX_ID=
# VECTOR_SEARCH_ENDPOINT_ID=
# VECTOR_SEARCH_DEPLOYED_INDEX_ID=
# VECTOR_SEARCH_PUBLIC_ENDPOINT_DOMAIN=
